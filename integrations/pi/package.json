{
  "name": "engram-pi",
  "version": "0.1.0",
  "description": "Pi.dev (pi-mono) extension that exposes Engram memory as slash commands and LLM tools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "engram": "file:../..",
    "typebox": "^1.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.78.1"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "engram",
    "pi",
    "pi-coding-agent",
    "memory",
    "extension"
  ],
  "license": "Apache-2.0"
}
